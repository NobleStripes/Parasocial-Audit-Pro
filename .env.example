# ANTHROPIC_API_KEY: Required for Claude API calls. Used server-side only.
# Never expose this to the Vite frontend bundle.
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEARCHER_MODE: Set to "true" to enable advanced forensic metrics and raw data exports.
RESEARCHER_MODE="true"

# DATA_EXPORT_TIER: Defines the fidelity of exported datasets (e.g., "standard", "high", "raw").
DATA_EXPORT_TIER="high"
